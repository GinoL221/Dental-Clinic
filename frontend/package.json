{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "start": "vite preview",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "typecheck": "tsc -p jsconfig.json --noEmit",
    "check": "svelte-check --tsconfig ./jsconfig.json",
    "format": "prettier --write \"**/*.{js,json,css,md,svelte}\"",
    "format:check": "prettier --check \"**/*.{js,json,css,md,svelte}\""
  },
  "devDependencies": {
    "@babel/preset-env": "7.29.7",
    "@playwright/test": "^1.42.1",
    "@sveltejs/adapter-auto": "7.0.1",
    "@sveltejs/kit": "^2.5.0",
    "@sveltejs/vite-plugin-svelte": "^3.0.0",
    "@types/node": "26.0.1",
    "jsdom": "^24.0.0",
    "prettier": "^3.3.2",
    "svelte": "^4.2.12",
    "svelte-check": "4.7.1",
    "typescript": "^5.5.3",
    "vite": "^5.1.0",
    "vitest": "^1.3.0"
  },
  "dependencies": {
    "dotenv": "^17.2.1"
  }
}
