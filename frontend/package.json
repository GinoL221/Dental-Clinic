{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "start": "node app.js",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "typecheck": "tsc -p jsconfig.json --noEmit",
    "format": "prettier --write \"**/*.{js,json,css,md,svelte}\"",
    "format:check": "prettier --check \"**/*.{js,json,css,md,svelte}\""
  },
  "devDependencies": {
    "@babel/preset-env": "7.29.7",
    "@playwright/test": "^1.42.1",
    "@sveltejs/adapter-auto": "7.0.1",
    "@sveltejs/kit": "^2.5.0",
    "@sveltejs/vite-plugin-svelte": "^3.0.0",
    "@types/express": "5.0.6",
    "@types/jest": "30.0.0",
    "@types/node": "26.0.1",
    "jest": "^29.0.0",
    "jest-environment-jsdom": "29.7.0",
    "jsdom": "^24.0.0",
    "nodemon": "^3.1.10",
    "prettier": "^3.3.2",
    "supertest": "^6.3.3",
    "svelte": "^4.2.12",
    "typescript": "^5.5.3",
    "vite": "^5.1.0",
    "vitest": "^1.3.0"
  },
  "dependencies": {
    "axios": "^1.11.0",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.2.1",
    "ejs": "^3.1.10",
    "express": "^5.1.0",
    "express-session": "^1.18.2",
    "express-validator": "^7.2.1"
  }
}
