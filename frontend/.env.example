# Frontend — Variables de entorno requeridas
# Copiar este archivo como .env y completar los valores reales
# NUNCA commitear el archivo .env

# Secreto para firmar las cookies de sesión de Express
# Usar una cadena larga y aleatoria en producción
SESSION_SECRET=reemplazar-con-valor-seguro

# Secreto JWT (debe coincidir con el valor configurado en el backend)
JWT_SECRET=reemplazar-con-valor-seguro

# URL del backend (por defecto apunta al local)
BACKEND_URL=http://localhost:8080

# Puerto del servidor frontend (por defecto 3000)
PORT=3000
